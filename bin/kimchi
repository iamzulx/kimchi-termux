#!/data/data/com.termux/files/usr/bin/bash
# Kimchi Termux launcher — rebuilt for Node.js
set -uo pipefail

KIMCHI_DIR="${KIMCHI_DIR:-$HOME/kimchi}"
BUNDLE="$KIMCHI_DIR/dist/kimchi-bundle.mjs"

if [ ! -f "$BUNDLE" ]; then
  echo "✗ Bundle not found: $BUNDLE" >&2
  exit 1
fi

export PI_PACKAGE_DIR="$KIMCHI_DIR/share/kimchi"
export PI_CODING_AGENT_DIR="$HOME/.config/kimchi/harness"
export PI_SKIP_VERSION_CHECK=1
export KIMCHI_DISABLE_BUILTIN_PROVIDERS=1
export NODE_OPTIONS="--max-old-space-size=2048"

ARGS="$*"

# === ROUTE 1: Interactive (needs stdin, user controls exit) ===
case "$ARGS" in
  setup*|login*|""|--continue*|-c|--continue|--resume*|-r|--resume)
    exec node "$BUNDLE" "$@"
    ;;
esac

# === ROUTE 2: Quick commands (output fast, event loop hangs → timeout kills it) ===
case "$1" in
  version|--version|-v|--help|-h|config|update|resources|--list-models)
    timeout 8 node --no-warnings "$BUNDLE" "$@"
    exit 0
    ;;
esac

# === ROUTE 3: Long commands (--print, --yolo, coding tasks) ===
# These take 10-60s for API response, so can't use short timeout.
# Background + monitor file + kill when output stabilizes.
OUTFILE=$(mktemp)
trap "rm -f $OUTFILE" EXIT

node --no-warnings "$BUNDLE" "$@" > "$OUTFILE" 2>&1 &
PID=$!

PREV_SIZE=0
STABLE=0
ELAPSED=0

while kill -0 "$PID" 2>/dev/null; do
  sleep 1
  ELAPSED=$((ELAPSED + 1))
  CUR_SIZE=$(stat -c%s "$OUTFILE" 2>/dev/null || echo 0)
  
  if [ "$CUR_SIZE" -eq "$PREV_SIZE" ] && [ "$CUR_SIZE" -gt 0 ]; then
    STABLE=$((STABLE + 1))
    if [ "$STABLE" -ge 3 ]; then
      kill -9 "$PID" 2>/dev/null
      break
    fi
  else
    STABLE=0
  fi
  PREV_SIZE=$CUR_SIZE
  
  if [ "$ELAPSED" -ge 300 ]; then
    kill -9 "$PID" 2>/dev/null
    break
  fi
done

wait "$PID" 2>/dev/null
cat "$OUTFILE"
exit 0
