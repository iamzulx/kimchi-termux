#!/data/data/com.termux/files/usr/bin/bash
# Kimchi Termux launcher — rebuilt for Node.js (no Bun, no glibc binary)
set -uo pipefail

KIMCHI_DIR="${KIMCHI_DIR:-$HOME/kimchi}"
BUNDLE="$KIMCHI_DIR/dist/kimchi-bundle.mjs"

if [ ! -f "$BUNDLE" ]; then
  echo "✗ Bundle not found: $BUNDLE" >&2
  echo "  Run: cd $KIMCHI_DIR && node scripts/build-bundle.mjs" >&2
  exit 1
fi

export PI_PACKAGE_DIR="$KIMCHI_DIR/share/kimchi"
export PI_CODING_AGENT_DIR="$HOME/.config/kimchi/harness"
export PI_SKIP_VERSION_CHECK=1
export KIMCHI_DISABLE_BUILTIN_PROVIDERS=1
export NODE_OPTIONS="--max-old-space-size=2048"

ARGS="$*"

# Interactive commands — run directly with stdin (no background)
case "$ARGS" in
  setup*|login*|""|--continue*|-c*|--resume*|-r*)
    exec node "$BUNDLE" "$@"
    ;;
esac

# Quick commands that exit naturally
case "$ARGS" in
  version*|--help*|-h|--version*|-v|--list-models*|config*)
    exec node "$BUNDLE" "$@"
    ;;
esac

# Non-interactive commands (print, coding tasks):
# Node.js event loop holds HTTP connections after CLI completes.
# Strategy: run in background, monitor output, force-exit when done.
TMPFILE=$(mktemp)
TMPERR=$(mktemp)
trap "rm -f $TMPFILE $TMPERR" EXIT

set +m
node "$BUNDLE" "$@" > "$TMPFILE" 2> "$TMPERR" &
NODE_PID=$!
disown "$NODE_PID" 2>/dev/null
set -m

PREV_SIZE=0
STABLE_COUNT=0
ELAPSED=0

while kill -0 "$NODE_PID" 2>/dev/null; do
  sleep 2
  ELAPSED=$((ELAPSED + 2))
  
  CUR_SIZE=$(wc -c < "$TMPFILE" 2>/dev/null || echo 0)
  
  if [ "$CUR_SIZE" -eq "$PREV_SIZE" ] && [ "$CUR_SIZE" -gt 0 ]; then
    STABLE_COUNT=$((STABLE_COUNT + 1))
    if [ "$STABLE_COUNT" -ge 2 ]; then
      kill -TERM "$NODE_PID" 2>/dev/null
      sleep 1
      kill -KILL "$NODE_PID" 2>/dev/null
      wait "$NODE_PID" 2>/dev/null
      cat "$TMPFILE"
      [ -s "$TMPERR" ] && cat "$TMPERR" >&2
      exit 0
    fi
  else
    STABLE_COUNT=0
  fi
  PREV_SIZE=$CUR_SIZE
  
  if [ "$ELAPSED" -ge 120 ]; then
    kill -TERM "$NODE_PID" 2>/dev/null
    sleep 1
    kill -KILL "$NODE_PID" 2>/dev/null
    wait "$NODE_PID" 2>/dev/null
    cat "$TMPFILE"
    [ -s "$TMPERR" ] && cat "$TMPERR" >&2
    exit 0
  fi
done

wait "$NODE_PID" 2>/dev/null
cat "$TMPFILE"
[ -s "$TMPERR" ] && cat "$TMPERR" >&2
exit 0
