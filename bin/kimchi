#!/data/data/com.termux/files/usr/bin/bash
# Kimchi Termux launcher — hardened for security
set -uo pipefail

# === SECURITY: Path validation ===
KIMCHI_DIR="${KIMCHI_DIR:-$HOME/kimchi}"
# Prevent path traversal
if [[ "$KIMCHI_DIR" == *..* ]]; then
  echo "✗ Invalid KIMCHI_DIR: path traversal detected" >&2
  exit 1
fi

BUNDLE="$KIMCHI_DIR/dist/kimchi-bundle.mjs"

if [ ! -f "$BUNDLE" ]; then
  echo "✗ Bundle not found: $BUNDLE" >&2
  exit 1
fi

# === SECURITY: Resource limits ===
# NOTE: Do NOT cap virtual memory (ulimit -v) for Node.js. V8 reserves a
# large *virtual* address space (zones/guard pages/code space) far bigger
# than the actual heap. Capping virtual memory makes V8's internal zone
# mmap() get denied by the kernel -> "Zone Allocation failed - out of
# memory" even while the real heap is nearly empty. Limit file size only.
ulimit -f 1048576 2>/dev/null || true  # File size: 1GB

# === SECURITY: Environment variables ===
export PI_PACKAGE_DIR="$KIMCHI_DIR/share/kimchi"
export PI_CODING_AGENT_DIR="$HOME/.config/kimchi/harness"
export PI_SKIP_VERSION_CHECK=1
export KIMCHI_DISABLE_BUILTIN_PROVIDERS=1
export KIMCHI_TELEMETRY_ENABLED=0  # CRITICAL: Disable telemetry
export NODE_OPTIONS="--max-old-space-size=1024"  # 1GB heap: safe for 3.7GB device

ARGS="$*"

# === SECURITY: Signal forwarding ===
# Forward SIGINT/SIGTERM to child process to prevent orphans
cleanup() {
  if [ -n "${CHILD_PID:-}" ] && kill -0 "$CHILD_PID" 2>/dev/null; then
    kill -TERM "$CHILD_PID" 2>/dev/null
    sleep 0.5
    kill -KILL "$CHILD_PID" 2>/dev/null
  fi
  rm -f "${OUTFILE:-}" 2>/dev/null
}
trap cleanup EXIT INT TERM

# === ROUTE 1: Interactive (needs stdin, user controls exit) ===
case "$ARGS" in
  setup*|login*|""|--continue*|-c|--continue|--resume*|-r|--resume)
    exec node "$BUNDLE" "$@"
    ;;
esac

# === ROUTE 2: Quick commands (output fast, event loop hangs → timeout kills it) ===
case "$1" in
  version|--version|-v|--help|-h|config|update|resources|--list-models)
    timeout 8 node --no-warnings "$BUNDLE" "$@"
    exit 0
    ;;
esac

# === ROUTE 3: Long commands (--print, --yolo, coding tasks) ===
# Background + monitor file + kill when output stabilizes
# SECURITY: Use explicit mktemp with 0600 permissions
OUTFILE=$(mktemp -t kimchi.XXXXXX)
chmod 600 "$OUTFILE"

node --no-warnings "$BUNDLE" "$@" > "$OUTFILE" 2>&1 &
CHILD_PID=$!

PREV_SIZE=0
STABLE=0
ELAPSED=0

while kill -0 "$CHILD_PID" 2>/dev/null; do
  sleep 1
  ELAPSED=$((ELAPSED + 1))
  CUR_SIZE=$(stat -c%s "$OUTFILE" 2>/dev/null || echo 0)
  
  if [ "$CUR_SIZE" -eq "$PREV_SIZE" ] && [ "$CUR_SIZE" -gt 0 ]; then
    STABLE=$((STABLE + 1))
    if [ "$STABLE" -ge 3 ]; then
      # SECURITY: Validate PID before kill (prevent PID reuse attack)
      if [ -d "/proc/$CHILD_PID" ]; then
        CMDLINE=$(cat "/proc/$CHILD_PID/cmdline" 2>/dev/null || echo "")
        if [[ "$CMDLINE" == *"node"* ]] && [[ "$CMDLINE" == *"kimchi-bundle.mjs"* ]]; then
          kill -TERM "$CHILD_PID" 2>/dev/null
          sleep 0.5
          kill -KILL "$CHILD_PID" 2>/dev/null
        fi
      fi
      break
    fi
  else
    STABLE=0
  fi
  PREV_SIZE=$CUR_SIZE
  
  if [ "$ELAPSED" -ge 300 ]; then
    # SECURITY: Validate PID before kill
    if [ -d "/proc/$CHILD_PID" ]; then
      CMDLINE=$(cat "/proc/$CHILD_PID/cmdline" 2>/dev/null || echo "")
      if [[ "$CMDLINE" == *"node"* ]] && [[ "$CMDLINE" == *"kimchi-bundle.mjs"* ]]; then
        kill -TERM "$CHILD_PID" 2>/dev/null
        sleep 0.5
        kill -KILL "$CHILD_PID" 2>/dev/null
      fi
    fi
    break
  fi
done

wait "$CHILD_PID" 2>/dev/null
cat "$OUTFILE"
exit 0
