#!/data/data/com.termux/files/usr/bin/bash
# Kimchi Termux launcher — hardened for security
set -uo pipefail

# === SECURITY: Path validation ===
KIMCHI_DIR="${KIMCHI_DIR:-$HOME/kimchi}"
if [[ "$KIMCHI_DIR" == *..* ]]; then
  echo "✗ Invalid KIMCHI_DIR: path traversal detected" >&2
  exit 1
fi

BUNDLE="$KIMCHI_DIR/dist/kimchi-bundle.mjs"

if [ ! -f "$BUNDLE" ]; then
  echo "✗ Bundle not found: $BUNDLE" >&2
  exit 1
fi

# === SECURITY: Resource limits ===
# Do NOT cap virtual memory (ulimit -v) — breaks V8 zone allocation on Termux.
ulimit -f 1048576 2>/dev/null || true

# === Optional 9router API key (not stored in models.json) ===
NINEROUTER_KEY_FILE="${NINEROUTER_KEY_FILE:-$HOME/.config/kimchi/9router_api_key}"
if [ -f "$NINEROUTER_KEY_FILE" ]; then
  export NINEROUTER_API_KEY="$(tr -d '\n\r' < "$NINEROUTER_KEY_FILE")"
fi

# === SECURITY: Environment variables ===
export PI_PACKAGE_DIR="$KIMCHI_DIR/share/kimchi"
export PI_CODING_AGENT_DIR="$HOME/.config/kimchi/harness"
export PI_SKIP_VERSION_CHECK=1
export KIMCHI_DISABLE_BUILTIN_PROVIDERS=1
export KIMCHI_TELEMETRY_ENABLED=0
export NODE_OPTIONS="--max-old-space-size=1024"

ARGS="$*"

# === SECURITY: Signal forwarding ===
is_our_node() {
  local pid="$1"
  [ -d "/proc/$pid" ] || return 1
  local cmd
  cmd=$(tr -d '\0' < "/proc/$pid/cmdline" 2>/dev/null || echo "")
  [[ "$cmd" == *"node"* ]] && [[ "$cmd" == *"kimchi-bundle.mjs"* ]]
}

cleanup() {
  if [ -n "${CHILD_PID:-}" ] && kill -0 "$CHILD_PID" 2>/dev/null; then
    if is_our_node "$CHILD_PID"; then
      kill -TERM "$CHILD_PID" 2>/dev/null
      sleep 0.5
      kill -KILL "$CHILD_PID" 2>/dev/null
    fi
  fi
  rm -f "${OUTFILE:-}" 2>/dev/null
}
trap cleanup EXIT INT TERM

# === ROUTE 1: Interactive (stdin required) ===
case "$ARGS" in
  setup*|login*|""|--continue*|-c|--continue|--resume*|-r|--resume)
    exec node "$BUNDLE" "$@"
    ;;
esac

# === ROUTE 2: Block official self-update on Termux ===
case "$1" in
  update)
    echo "✗ kimchi update is disabled on this Termux build." >&2
    echo "  Official updates replace the bundle with a Bun/glibc binary that does not run here." >&2
    echo "  To upgrade: pull iamzulx/kimchi-termux, re-apply patches, run: node scripts/build-bundle.mjs" >&2
    exit 1
    ;;
esac

# === ROUTE 2b: Quick commands ===
case "$1" in
  version|--version|-v|--help|-h|config|resources|--list-models)
    timeout 8 node --no-warnings "$BUNDLE" "$@"
    exit $?
    ;;
esac

# === ROUTE 3: Long commands (--print, --yolo, coding tasks) ===
OUTFILE=$(mktemp -t kimchi.XXXXXX)
chmod 600 "$OUTFILE"

node --no-warnings "$BUNDLE" "$@" >"$OUTFILE" 2>&1 &
CHILD_PID=$!

PREV_SIZE=0
STABLE=0
ELAPSED=0

while kill -0 "$CHILD_PID" 2>/dev/null; do
  sleep 1
  ELAPSED=$((ELAPSED + 1))
  CUR_SIZE=$(stat -c%s "$OUTFILE" 2>/dev/null || echo 0)

  if [ "$CUR_SIZE" -gt "$PREV_SIZE" ] && [ "$CUR_SIZE" -gt 0 ]; then
    tail -c +$((PREV_SIZE + 1)) "$OUTFILE" 2>/dev/null || true
    PREV_SIZE=$CUR_SIZE
    STABLE=0
  elif [ "$CUR_SIZE" -eq "$PREV_SIZE" ] && [ "$CUR_SIZE" -gt 0 ]; then
    STABLE=$((STABLE + 1))
    if [ "$STABLE" -ge 3 ]; then
      if is_our_node "$CHILD_PID"; then
        kill -TERM "$CHILD_PID" 2>/dev/null
        sleep 0.5
        kill -KILL "$CHILD_PID" 2>/dev/null
      fi
      break
    fi
  else
    STABLE=0
  fi

  if [ "$ELAPSED" -ge 300 ]; then
    if is_our_node "$CHILD_PID"; then
      kill -TERM "$CHILD_PID" 2>/dev/null
      sleep 0.5
      kill -KILL "$CHILD_PID" 2>/dev/null
    fi
    break
  fi
done

wait "$CHILD_PID" 2>/dev/null || true
if [ -f "$OUTFILE" ]; then
  CUR_SIZE=$(stat -c%s "$OUTFILE" 2>/dev/null || echo 0)
  if [ "$CUR_SIZE" -gt "$PREV_SIZE" ]; then
    tail -c +$((PREV_SIZE + 1)) "$OUTFILE" 2>/dev/null || true
  fi
fi
exit 0