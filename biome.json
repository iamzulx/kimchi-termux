{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded"
		}
	},
	"overrides": [
		{
			"include": ["src/extensions/thinking-steps/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noControlCharactersInRegex": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					},
					"complexity": {
						"noForEach": "off"
					}
				}
			}
		},
		{
			"include": ["src/extensions/pi-compat.test.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	],
	"files": {
		"ignore": ["dist/", "node_modules/", "src/core/export-html/", "src/extensions/mcp-adapter/", "src/extensions/tool-rendering.ts"]
	}
}
